pipeline {

    agent { label 'deploy-agent-deploy' }

    options { 
        skipDefaultCheckout(true) 
    }

    environment {
        JFROG_URL = "http://192.168.56.1:8082/artifactory/ecommerce-backend"
        DEPLOY_PATH = "C:\\inetpub\\ecommerce-api"
        TEMP_PATH = "C:\\temp\\backend-deploy"
        BACKUP_PATH = "C:\\temp\\backend-backup"
    }

    stages {

        stage('Prepare Temp & Backup') {
            steps {
                bat '''
                REM Cleanup temp
                if exist %TEMP_PATH% rmdir /s /q %TEMP_PATH%
                mkdir %TEMP_PATH%

                REM Cleanup backup
                if exist %BACKUP_PATH% rmdir /s /q %BACKUP_PATH%
                mkdir %BACKUP_PATH%

                REM Backup configs
                if exist %DEPLOY_PATH%\\web.config copy %DEPLOY_PATH%\\web.config %BACKUP_PATH%
                if exist %DEPLOY_PATH%\\appsettings.json copy %DEPLOY_PATH%\\appsettings.json %BACKUP_PATH%

                REM Backup logs folder
                if exist %DEPLOY_PATH%\\logs xcopy %DEPLOY_PATH%\\logs %BACKUP_PATH%\\logs /E /I /Y
                '''
            }
        }

        stage('Download Artifact') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'artifactory-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    bat '''
                    curl.exe -u %USER%:%PASS% -o %TEMP_PATH%\\backend.zip %JFROG_URL%/latest.zip
                    '''
                }
            }
        }

        stage('Extract Artifact') {
            steps {
                bat '''
                powershell Expand-Archive -Path %TEMP_PATH%\\backend.zip -DestinationPath %TEMP_PATH% -Force
                '''
            }
        }

        stage('Clean Deploy Folder (SAFE)') {
            steps {
                bat '''
                if exist %DEPLOY_PATH% (
                    rmdir /s /q %DEPLOY_PATH%
                )
                mkdir %DEPLOY_PATH%
                '''
            }
        }

        stage('Deploy Files') {
            steps {
                bat '''
                xcopy %TEMP_PATH%\\* "%DEPLOY_PATH%\\" /E /H /C /I /Y
                '''
            }
        }

        stage('Restore Configs & Logs') {
            steps {
                bat '''
                REM Restore configs
                if exist %BACKUP_PATH%\\web.config copy %BACKUP_PATH%\\web.config %DEPLOY_PATH%
                if exist %BACKUP_PATH%\\appsettings.json copy %BACKUP_PATH%\\appsettings.json %DEPLOY_PATH%

                REM Restore logs
                if exist %BACKUP_PATH%\\logs xcopy %BACKUP_PATH%\\logs %DEPLOY_PATH%\\logs /E /I /Y
                '''
            }
        }

        stage('Cleanup Temp') {
            steps {
                bat '''
                rmdir /s /q %TEMP_PATH%
                rmdir /s /q %BACKUP_PATH%
                '''
            }
        }

        stage('Restart IIS') {
            steps {
                bat 'iisreset'
            }
        }
    }

    post {
        success {
            echo "✅ Backend Deployment SUCCESS (Configs + Logs Preserved)"
        }
        failure {
            echo "❌ Backend Deployment FAILED"
        }
    }
}
