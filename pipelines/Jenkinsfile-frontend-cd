pipeline {

    agent { label 'deploy-agent-deploy' }

    options {
        skipDefaultCheckout(true)
    }

    environment {
        JFROG_URL = "http://192.168.56.1:8082/artifactory/ecommerce-frontend"
        DEPLOY_PATH = "C:\\inetpub\\ecommerce-ui"
        TEMP_PATH = "C:\\temp\\frontend-deploy"
    }

    stages {

        stage('Prepare Temp Directory') {
            steps {
                bat '''
                if exist %TEMP_PATH% (
                    rmdir /s /q %TEMP_PATH%
                )
                mkdir %TEMP_PATH%
                '''
            }
        }

        stage('Create Exclude File') {   // 🔥 MOVED UP
            steps {
                writeFile file: 'exclude.txt', text: '''
web.config
'''
            }
        }

        stage('Download Artifact from JFrog') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'artifactory-creds', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    bat '''
                    curl.exe -u %USER%:%PASS% -o %TEMP_PATH%\\frontend.zip %JFROG_URL%/latest.zip
                    '''
                }
            }
        }

        stage('Extract Artifact') {
            steps {
                bat '''
                powershell Expand-Archive -Path %TEMP_PATH%\\frontend.zip -DestinationPath %TEMP_PATH% -Force
                '''
            }
        }

        stage('Deploy (Preserve web.config)') {
            steps {
                bat '''
                REM 🔥 Copy ONLY browser files & DO NOT overwrite web.config

                for /d %%i in (%TEMP_PATH%\\*) do (
                    if exist "%%i\\browser" (
                        xcopy "%%i\\browser\\*" "%DEPLOY_PATH%\\" /E /H /C /I /Y /EXCLUDE:exclude.txt
                    )
                )
                '''
            }
        }

        stage('Cleanup Temp') {
            steps {
                bat '''
                rmdir /s /q %TEMP_PATH%
                '''
            }
        }

        stage('Restart App Pool') {
            steps {
                powershell 'Restart-WebAppPool -Name "ecommerce-ui"'
            }
        }
    }

    post {
        success {
            echo "✅ Frontend Deployment SUCCESS (Safe + Clean + No Config Loss)"
        }
        failure {
            echo "❌ Frontend Deployment FAILED"
        }
    }
}
